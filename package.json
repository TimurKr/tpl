{
  "name": "tpl-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter='./packages/core' build && bun run --filter='./packages/cli' build",
    "test": "bun run --filter='./packages/*' test",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "clean": "bun run --filter='*' clean",
    "dev:example": "bun run --cwd apps/example dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "typescript": "^5.4.5"
  }
}
