{
  "name": "@tpl/core",
  "version": "0.10.0",
  "description": "Core parser and codegen engine for TPL — The Prompting Library.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "prompt",
    "prompting",
    "llm",
    "ai",
    "codegen",
    "typescript",
    "template",
    "type-safe"
  ],
  "author": {
    "name": "Timur Kramár",
    "url": "https://github.com/timurkramar"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/timurkramar/tpl.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/timurkramar/tpl#readme",
  "bugs": {
    "url": "https://github.com/timurkramar/tpl/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3"
  }
}
